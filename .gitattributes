# Force LF endings on shell scripts so they execute on the Linux runner
# regardless of contributor OS. Same goes for YAML/JSON tooling configs.
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.properties text eol=lf

# Gradle wrapper — POSIX shell script (LF) and Windows batch (CRLF), respectively.
android/gradlew     text eol=lf
android/gradlew.bat text eol=crlf

# Treat the keystore + the gradle wrapper jar as sealed binaries. Flagging
# them as binary prevents accidental EOL-conversion mangling and disables
# diffs that would never be informative anyway.
keystore/ci.keystore                    binary
android/gradle/wrapper/gradle-wrapper.jar binary
