<?xml version="1.0" encoding="utf-8"?>
<!-- Disable Android's "Auto Backup" + "Device Transfer" extraction.
     SPEC §11: no telemetry, no analytics; user-data leaving the device by any
     channel is opt-in, never default. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
