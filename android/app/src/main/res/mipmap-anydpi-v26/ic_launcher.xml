<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (Android 8+). The system composites foreground
  over background and clips into whatever shape the launcher picks
  (circle, square, squircle, teardrop).

  We DO NOT include a <monochrome> layer here. The brand monochrome
  asset is just the octagon outline (the eye/center is intentionally
  blank in the brand spec) — when MagicOS / Pixel Themed-Icons mode is
  active, the system tints just the outline against a system-controlled
  background which on light-themed wallpapers reads as "white background
  with a faint outline". That looked broken to the user.

  Without <monochrome>, the launcher cannot opt into Themed Icons for
  this app and falls back to the foreground+background composite — which
  is the brand-correct rendering (Crimson eye over Obsidian octagon).
  Themed-Icons can come back in Phase 3 with a hand-tuned monochrome
  asset that reads correctly against any system surface.

  Source assets: C:/Code/claude/brands/songbird/so-mi/.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
