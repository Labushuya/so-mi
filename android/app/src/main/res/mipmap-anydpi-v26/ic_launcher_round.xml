<?xml version="1.0" encoding="utf-8"?>
<!--
  Round-icon variant. Same composition as ic_launcher.xml; some launchers
  prefer a separately-declared round alias even though adaptive icons
  clip on demand. No monochrome layer for the same reason as the main
  icon.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
