<?xml version="1.0" encoding="utf-8"?>
<!--
  Round-icon variant. Same composition as ic_launcher.xml; some launchers
  (Pixel 2's circular indicator, etc.) prefer a separately-declared round
  alias even though adaptive icons clip on demand. We use the same three
  layers either way — the brand octagon clips cleanly into a circle.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
    <monochrome android:drawable="@mipmap/ic_launcher_monochrome" />
</adaptive-icon>
