<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Songbird Phase-1 base theme.

         Compose Material3 paints all in-app surfaces. This theme only governs
         the one-frame system-window flash before setContent runs (windowBackground
         keeps the cold-launch backdrop Obsidian instead of white).

         v0.13.0: removed deprecated android:statusBarColor / navigationBarColor /
         windowLightStatusBar / windowLightNavigationBar — all four are no-ops on
         targetSdk 35 (Android 15+) and the actual bar tint is now controlled by
         enableEdgeToEdge(SystemBarStyle.dark(...)) in MainActivity.onCreate. -->
    <style name="Theme.SoMi" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/songbird_obsidian</item>
        <!-- v0.15.0: opt into drawing under display cutouts (notch, punch-hole)
             so the immersive mode reaches every pixel. shortEdges = top+bottom
             cutouts allowed, side cutouts in landscape get black bars. -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
